# docker-compose 실행 시 사용할 환경변수 예시
# 이 파일을 복사해서 .env로 만들고 값을 채워넣으세요 (.env는 git에 올리지 마세요)

SECRET_KEY=change-me-to-a-random-secret

# 기본값은 SQLite (컨테이너 내부 /app/instance/pharma.db).
# PostgreSQL 등을 쓰려면 아래 형식으로 지정:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# 비밀번호 재설정 메일 발송용 (Gmail 앱 비밀번호 권장)
MAIL_USERNAME=
MAIL_PASSWORD=

# 식약처 낱알식별 OpenAPI 키
MFDS_API_KEY=

# PubMed 논문 요약용 Claude API 키
ANTHROPIC_API_KEY=
